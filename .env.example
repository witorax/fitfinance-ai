# Copie ce fichier en ".env" pour le developpement local avec `netlify dev`.
# Ne jamais commiter le fichier ".env" reel.

# Cle API Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Projet Supabase (Dashboard > Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
